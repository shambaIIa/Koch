// Koç Platformu - Prisma şeması
// Geliştirme: SQLite. Postgres'e taşınabilir (enum yerine String, json yerine String).
// Çoklu kiracı izolasyonu uygulama/veri katmanında coachId ile sağlanır.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Çekirdek: Koç (kiracı) ----
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("coach") // coach | student (ileride)
  createdAt    DateTime @default(now())

  students        Student[]
  moduleSettings  ModuleSetting[]
  exams           Exam[]
  studyTasks      StudyTask[]
  meetingNotes    MeetingNote[]
  signals         Signal[]
  ocrJobs         OcrJob[]
}

// ---- Çekirdek: Öğrenci profili ----
model Student {
  id               String   @id @default(cuid())
  coachId          String
  name             String
  grade            String?  // 12, mezun, 11 ...
  track            String?  // sayisal | esit | sozel | dil
  targetUniversity String?
  targetNetTyt     Float?
  targetNetAyt     Float?
  notes            String?
  archived         Boolean  @default(false)
  createdAt        DateTime @default(now())

  coach        User          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  exams        Exam[]
  studyTasks   StudyTask[]
  meetingNotes MeetingNote[]
  signals      Signal[]
  parent       Parent?
  parentVisibility ParentVisibility?
  weeklySummaries  WeeklySummary[]
  ocrJobs      OcrJob[]

  @@index([coachId])
}

// ---- Modüler mimari: feature-flag ----
model ModuleSetting {
  id        String   @id @default(cuid())
  coachId   String
  moduleKey String   // parent | motivation | library | video | notifications
  enabled   Boolean  @default(false)
  config    String?  // JSON string
  updatedAt DateTime @default(now()) @updatedAt

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, moduleKey])
  @@index([coachId])
}

// ---- Çekirdek: Deneme ----
model Exam {
  id        String   @id @default(cuid())
  coachId   String
  studentId String
  name      String
  type      String   // TYT | AYT
  provider  String?
  date      DateTime
  createdAt DateTime @default(now())

  coach    User          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student  Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjects ExamSubject[]

  @@index([studentId])
  @@index([coachId])
}

model ExamSubject {
  id           String @id @default(cuid())
  examId       String
  subject      String
  questionCount Int
  correct      Int    @default(0)
  wrong        Int    @default(0)
  blank        Int    @default(0)
  net          Float  @default(0) // correct - wrong/4

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

// ---- Çekirdek: Çalışma planı ----
model StudyTask {
  id          String    @id @default(cuid())
  coachId     String
  studentId   String
  title       String
  subject     String?
  dueDate     DateTime?
  status      String    @default("pending") // pending | done
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  coach   User    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ---- Çekirdek: Görüşme notları ----
model MeetingNote {
  id        String   @id @default(cuid())
  coachId   String
  studentId String
  date      DateTime @default(now())
  summary   String
  content   String?
  createdAt DateTime @default(now())

  coach   User    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ---- Kural motoru çıktısı: sinyaller (görüşme gündemi kaynağı) ----
model Signal {
  id              String   @id @default(cuid())
  coachId         String
  studentId       String
  type            String   // net_decline | net_improve | high_blank | high_wrong | volatility | target_gap | plan_gap | data_gap | balance
  scope           String   // subject | overall | behavioral
  severity        String   // info | low | medium | high
  title           String
  message         String
  suggestedAction String?
  payload         String?  // JSON
  dedupeKey       String
  status          String   @default("open") // open | dismissed | resolved
  createdAt       DateTime @default(now())

  coach   User    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, dedupeKey])
  @@index([studentId])
  @@index([coachId])
}

// ---- Anahtarlanabilir: Veli ----
model Parent {
  id           String   @id @default(cuid())
  studentId    String   @unique
  name         String
  contactEmail String?
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// Üç seviyeli görünürlük kontrolü (hesap / öğrenci / içerik)
model ParentVisibility {
  id                   String  @id @default(cuid())
  studentId            String  @unique
  accountEnabled       Boolean @default(true)  // hesap seviyesi
  shareEnabled         Boolean @default(true)  // öğrenci seviyesi
  showPlanProgress     Boolean @default(true)  // içerik seviyesi
  showExamParticipation Boolean @default(true)
  showTrend            Boolean @default(true)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model WeeklySummary {
  id          String   @id @default(cuid())
  studentId   String
  periodStart DateTime
  periodEnd   DateTime
  content     String   // nötr, net içermez
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ---- Eklenti (Faz 3) hazır: OCR işleri ----
model OcrJob {
  id           String   @id @default(cuid())
  coachId      String
  studentId    String?
  examId       String?
  storageKey   String
  provider     String   @default("vision") // vision | omr
  status       String   @default("pending") // pending | processing | review_needed | done | failed
  rawResult    String?  // JSON
  parsedResult String?  // JSON
  confidence   Float?
  createdAt    DateTime @default(now())

  coach   User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([coachId])
}
